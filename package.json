{
  "name": "pyxis",
  "version": "0.1.0",
  "description": "Semantic router built on real embeddings + hybrid search. Named after Pyxis — the mariner's compass constellation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "pyxis-mcp": "./dist/mcp-server.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "mcp": "node dist/mcp-server.js"
  },
  "keywords": [
    "semantic-router",
    "vector-search",
    "hybrid-search",
    "embeddings",
    "ai-agent",
    "rag",
    "minisearch",
    "transformers"
  ],
  "author": "jjwallace",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jjwallace/pyxis.git"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "minisearch": "^7.1.1",
    "usearch": "^2.25.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "trustedDependencies": [
    "tree-sitter-rust"
  ]
}
